# Copy to .env and fill in. Only BOT_TOKEN is required.

# From @BotFather
BOT_TOKEN=

# Optional: where downloads are staged before upload (defaults to a temp dir).
# DOWNLOAD_DIR=/tmp/tgdl

# Optional: cap file size in MB. Telegram's bot upload limit is 50, so values
# above 50 are clamped to 50.
# MAX_FILESIZE_MB=50
